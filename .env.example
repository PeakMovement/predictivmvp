# ─────────────────────────────────────────────────────────────────────────────
# Predictiv — environment reference
#
# FRONTEND (.env / Netlify build env) — these are PUBLIC (bundled into the app).
# Never put a secret here; the Supabase anon key is public by design and is
# protected by Row Level Security.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://ixtwbkikyuexskdgfpfq.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# EDGE FUNCTION SECRETS — set in Supabase → Project Settings → Edge Functions.
# NOT in this file, NOT in git. Listed here only as a reference of what's needed.
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically.
# ─────────────────────────────────────────────────────────────────────────────

# App URLs (used for OAuth redirects + email links)
APP_URL=https://predictiv.netlify.app
FRONTEND_URL=https://predictiv.netlify.app

# Google Calendar  (Google Cloud → APIs & Services → Credentials)
# GOOGLE_REDIRECT_URI must match the Authorized redirect URI EXACTLY.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://predictiv.netlify.app/google-calendar-callback

# Oura  (https://cloud.ouraring.com/oauth/applications)
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=https://predictiv.netlify.app/oauth/callback/oura
OURA_WEBHOOK_VERIFICATION_TOKEN=

# Garmin  (Garmin Developer Portal — Wellness API)
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
GARMIN_REDIRECT_URI=

# Polar  (https://admin.polaraccesslink.com)
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=

# Email — Resend (https://resend.com)
# RESEND_FROM must use a VERIFIED domain in production.
# RESEND_TO_OVERRIDE redirects ALL mail to one inbox — unset it in production!
RESEND_API_KEY=
RESEND_FROM=Predictiv <hello@peakmovement.co.za>
RESEND_TO_OVERRIDE=

# Billing — Stripe (required only once subscription gating goes live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=

# AI providers
LOVABLE_API_KEY=
OPENAI_API_KEY=
